[user]
	name = ShujiOba
	email = shuji365630@gmail.com
[core]
	editor = nvim -f
	excludesfile = /Users/oba/.gitignore_global
[color]
	ui = auto
[commit]
	template = ~/.commit_template
[alias]
	a = add
	c = commit

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
